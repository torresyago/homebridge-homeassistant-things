{
  "pluginAlias": "HomeAssistantThing",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "HA Things"
      },
      "haUrl": {
        "title": "Default Home Assistant URL",
        "type": "string",
        "placeholder": "http://homeassistant.local:8123",
        "description": "Default HA URL for all devices. Can be overridden per device."
      },
      "haToken": {
        "title": "Default Long-Lived Access Token",
        "type": "string",
        "description": "Default HA token for all devices. Can be overridden per device."
      },
      "devices": {
        "title": "Devices",
        "type": "array",
        "items": {
          "title": "Device",
          "type": "object",
          "required": ["name", "deviceType", "entityId"],
          "properties": {
            "name": {
              "title": "Name",
              "type": "string",
              "default": "My Device",
              "description": "Display name in the Home app"
            },
            "deviceType": {
              "title": "Device Type",
              "type": "string",
              "default": "switch",
              "oneOf": [
                { "title": "Switch / Light", "enum": ["switch"] },
                { "title": "Thermostat (climate entity)", "enum": ["thermostat"] },
                { "title": "Blind / Shutter (cover entity)", "enum": ["blind"] },
                { "title": "Garage Door (pulse relay)", "enum": ["garageDoor"] },
                { "title": "Sensor (read-only numeric, e.g. power/energy)", "enum": ["sensor"] },
                { "title": "Pulse (momentary switch — auto turn_off after pulseTime)", "enum": ["pulse"] },
                { "title": "Button (stateless — triggers HomeKit automations)", "enum": ["button"] }
              ]
            },
            "haUrl": {
              "title": "Home Assistant URL",
              "type": "string",
              "placeholder": "http://homeassistant.local:8123"
            },
            "entityId": {
              "title": "Entity ID",
              "type": "string",
              "description": "switch.salon · light.bedroom · climate.salon · cover.persiana · switch.relay",
              "placeholder": "switch.salon"
            },
            "haToken": {
              "title": "Long-Lived Access Token",
              "type": "string"
            },
            "pollInterval": {
              "title": "Poll Interval (seconds)",
              "type": "integer",
              "default": 30,
              "minimum": 5
            },
            "openingTime": {
              "title": "Opening Time (seconds)",
              "type": "integer",
              "default": 15,
              "minimum": 1,
              "description": "How long the door takes to fully open",
              "condition": {
                "functionBody": "return model.deviceType === 'garageDoor'"
              }
            },
            "closingTime": {
              "title": "Closing Time (seconds)",
              "type": "integer",
              "default": 15,
              "minimum": 1,
              "description": "How long the door takes to fully close",
              "condition": {
                "functionBody": "return model.deviceType === 'garageDoor'"
              }
            },
            "pulseTime": {
              "title": "Relay Pulse Duration (ms)",
              "type": "integer",
              "default": 2000,
              "minimum": 100,
              "description": "How long the relay stays on (in milliseconds)",
              "condition": {
                "functionBody": "return model.deviceType === 'garageDoor'"
              }
            }
          }
        }
      }
    }
  }
}
